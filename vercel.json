{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/briefing",
      "dest": "/api/briefing.js"
    },
    {
      "src": "/api/stocks",
      "dest": "/api/stocks.js"
    },
    {
      "src": "/api/naver-finance",
      "dest": "/api/naver-finance.js"
    },
    {
      "src": "/api/health",
      "dest": "/api/health.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
